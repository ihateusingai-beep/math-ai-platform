# MathAI Platform — Environment Variables
# Copy this file to .env and fill in your values

# ========================================
# LLM Configuration
# ========================================

# Ollama (本地)
# 預設：http://localhost:11434
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=llama3.2

# MiniMax (雲端)
# 獲取方式：https://platform.minimax.chat/
MINIMAX_API_KEY=your_m...here

# DeepSeek (備用)
DEEPSEEK_API_KEY=your_d...here

# Qwen (最後備用)
QWEN_API_KEY=your_q...here

# ========================================
# Image Generation (Optional)
# ========================================
# MiniMax Image API — 用於生成教學圖卡
# 取得key: https://platform.minimax.chat/
# 留空則停用圖卡功能（wish list on/off）
MINIMAX_IMAGE_API_KEY=

# ========================================
# Server Configuration
# ========================================

PORT=3000
NODE_ENV=development